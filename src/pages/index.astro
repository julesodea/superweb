---
import { GridPattern } from "../components/GridPattern";
import { Hero } from "../components/Hero";
import Layout from "../layouts/Layout.astro";
---

<Layout title="superweb - Digital Products for the future.">
  <main class="min-h-screen flex flex-col">
    {/* Hero Section with Grid Background */}
    <section class="relative">
      {/* SVG Grid Background */}

      {/* Hero Content */}
      <div class="relative z-10">
        <Hero client:load />
      </div>
    </section>
    <section class="bg-[#1C1C1E] py-24">
      {/* Dotted Grid Background */}

      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <div
            class="inline-flex items-center justify-center px-4 py-2 mb-6 rounded-full bg-gray-800/50"
          >
            <span class="text-white">Services</span>
          </div>

          <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
            We have the best services possible
          </h2>
          <p class="text-gray-400 text-xl">
            Our services will be your top priority.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {/* Service Cards */}
          <div
            class="relative bg-gray-600/30 rounded-3xl p-8 backdrop-blur-sm overflow-hidden group"
          >
            <div class="relative z-10">
              <h3 class="text-white text-2xl font-semibold mb-4">Design</h3>
              <p class="text-gray-400">
                Our AI providers never store your information. This sentence
                needs to be longer for the card to look good.
              </p>
            </div>
          </div>
          <div
            style={{
              backgroundImage:
                "radial-gradient( circle farthest-corner, rgba(0,0,0,.1) 1px, transparent 1px )",
              backgroundSize: "25px 25px",
            }}
            class="border rounded-xl p-6 max-w-4xl shadow-xl text-gray-900 bg-white flex flex-col items-center justify-center space-y-6"
          >
            <h1
              class="text-center bg-white bg-opacity-70 font-semibold text-3xl sm:text-4xl py-3 px-6 rounded-xl"
            >
              Design
            </h1>
            <p
              class="text-center text-lg text-gray-600 py-6 bg-white bg-opacity-70 rounded-lg"
            >
              Paragraph about the card content that has a sentence about this
              long so I can show the card size with actual content existing in
              it.
            </p>
          </div>
          <div
            class="relative bg-gray-600/30 rounded-3xl p-8 backdrop-blur-sm overflow-hidden group"
          >
            <div class="relative z-10">
              <h3 class="text-white text-2xl font-semibold mb-4">
                Development
              </h3>
              <p class="text-gray-400">
                Your data is encrypted at rest and in transit, processed on our
                servers in your region of choice. Some more words here.
              </p>
            </div>
            <div
              class="absolute inset-0 bg-gradient-to-b from-gray-800/0 to-gray-800/20 opacity-0 group-hover:opacity-100 transition-opacity"
            >
            </div>
          </div>

          <div
            class="relative bg-gray-600/30 rounded-3xl p-8 backdrop-blur-sm overflow-hidden group"
          >
            <div class="relative z-10">
              <h3 class="text-white text-2xl font-semibold mb-4">Deployment</h3>
              <p class="text-gray-400">
                Your data is never used to train general AI models. A few more
                words at the end here rounds it off.
              </p>
            </div>
          </div>
          <div
            class="relative bg-neutral-50 rounded-3xl p-8 backdrop-blur-sm overflow-hidden group"
          >
            {/* Dotted Background */}
            <div
              class="absolute inset-0 pointer-events-none opacity-10"
              style={{
                backgroundImage: `radial-gradient(circle at center, rgba(1, 1, 1, 1) 1px, transparent 0.2px)`,
                backgroundSize: "24px 24px",
              }}
            >
            </div>

            <div class="relative z-10">
              <h3 class="text-dark text-2xl font-semibold mb-4">Development</h3>
              <p class="text-gray-400">
                Your data is encrypted at rest and in transit, processed on our
                servers in your region of choice. Some more words here.
              </p>
            </div>
            <div
              class="absolute inset-0 bg-gradient-to-b from-white/0 to-white/5 opacity-0 group-hover:opacity-100 transition-opacity"
            >
            </div>
          </div>
          <div
            class="relative bg-gray-600/30 rounded-3xl p-8 backdrop-blur-sm overflow-hidden group"
          >
            {/* Dotted Background */}
            <div
              class="absolute inset-0 pointer-events-none opacity-10"
              style={{
                backgroundImage: `radial-gradient(circle at center, rgba(255, 255, 255, 1) 1px, transparent 1px)`,
                backgroundSize: "24px 24px",
              }}
            >
            </div>

            <div class="relative z-10">
              <h3 class="text-white text-2xl font-semibold mb-4">
                Development
              </h3>
              <p class="text-gray-400">
                Your data is encrypted at rest and in transit, processed on our
                servers in your region of choice. Some more words here.
              </p>
            </div>
            <div
              class="absolute inset-0 bg-gradient-to-b from-white/0 to-white/5 opacity-0 group-hover:opacity-100 transition-opacity"
            >
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="min-h-80">
      <div
        class="flex justify-center border min-h-80 rounded-lg shadow-sm mx-4 my-4 lg:mx-auto lg:max-w-7xl"
      >
        <div class="flex gap-4 items-center flex-col justify-center px-6 py-4">
          <div class="flex items-center">
            <h2 class="text-4xl md:text-5xl font-bold mb-4">
              superweb Contact
            </h2>
          </div>

          <div
            class="hidden md:flex items-center text-center space-x-8 max-w-2xl"
          >
            <p>
              We are yabber dabber doo working from bedrock to bring you the
              best and most prehistoric web solutions to a flinstone near you.
            </p>
          </div>

          <div>
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-2xl bg-black text-white px-5 py-5 text-lg font-semibold hover:bg-black/90 transition-colors w-full"
            >
              Get Started
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
