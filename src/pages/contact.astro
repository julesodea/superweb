---
import Button from "../components/Button";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Superweb - Digital Products for the future.">
  <main
    class="h-[100vh] mx-auto px-4 py-16 max-w-5xl flex items-center justify-center"
  >
    <div class="grid md:grid-cols-2 gap-6 items-center justify-center">
      <div class="text-center md:text-left p-6">
        <h2 class="text-3xl md:text-5xl font-bold text-dark mb-4">Contact</h2>
        <p class="text-gray-400 text-lg md:text-xl mb-6">
          Our services will be your top priority.
        </p>
        <p class="text-sm text-muted-foreground mb-8">
          Send us a message and we'll get back to you as soon as possible.
        </p>
      </div>

      <div class="w-full max-w-md mx-auto p-6">
        <form
          id="my-form"
          action="https://formspree.io/f/xrbglpjg"
          method="POST"
          class="space-y-6"
        >
          <div class="space-y-2">
            <label for="email" class="block text-sm font-medium text-gray-700">
              Email address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="Enter your email"
              class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm
                     focus:outline-none focus:ring-2 focus:ring-blue-500
                     transition duration-200 ease-in-out"
            />
          </div>

          <div class="space-y-2">
            <label
              for="message"
              class="block text-sm font-medium text-gray-700"
            >
              Your message
            </label>
            <textarea
              id="message"
              name="message"
              required
              placeholder="How can we help you?"
              class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm
                     min-h-[150px] resize-none
                     focus:outline-none focus:ring-2 focus:ring-blue-500
                     transition duration-200 ease-in-out"
            ></textarea>
          </div>

          <div class="flex justify-center md:justify-start">
            <Button type="submit" variant="light">
              Send Message
              <img
                src="/arrow-right.svg"
                alt="arrow right"
                width={15}
                height={15}
                class="ml-2 group-hover:translate-x-1 transition-transform duration-200"
              />
            </Button>
          </div>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById("my-form") as HTMLFormElement;

  async function handleSubmit(event: any) {
    event.preventDefault();

    try {
      const response = await fetch(event.target.action, {
        method: form?.method,
        body: new FormData(event.target),
        headers: {
          Accept: "application/json",
        },
      });

      if (response.ok) {
        window.location.href = "/success";
      } else {
        window.location.href = "/";
      }
    } catch (error) {
      alert("Error! Please try again.");
    }
  }

  form?.addEventListener("submit", handleSubmit);
</script>
